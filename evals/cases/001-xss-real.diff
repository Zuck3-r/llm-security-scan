 import React from "react";

+type Comment = { id: string; body: string };
+
+// 一覧ページから呼ばれる。comments は GET /api/comments のレスポンスで、
+// DB に保存されたユーザー投稿テキスト (body) がそのまま JSON で返ってくる。
+export function CommentList(props: { comments: Comment[] }) {
+  return (
+    <ul>
+      {props.comments.map((c) => (
+        <li key={c.id}>
+          <CommentBody comment={c.body} />
+        </li>
+      ))}
+    </ul>
+  );
+}
+
 export function CommentBody(props: { comment: string }) {
-  return (
-    <p>{props.comment}</p>
-  );
+  // ユーザー投稿コメントをそのまま HTML として埋め込む
+  // (管理画面プレビューで markdown を表示したかった)
+  return (
+    <div
+      className="comment-body"
+      dangerouslySetInnerHTML={{ __html: props.comment }}
+    />
+  );
 }
