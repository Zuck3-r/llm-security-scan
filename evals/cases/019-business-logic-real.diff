diff --git a/app/services/coupon_service.rb b/app/services/coupon_service.rb
index e69de29..c7a8b3d 100644
--- a/app/services/coupon_service.rb
+++ b/app/services/coupon_service.rb
@@ -0,0 +1,16 @@
+class CouponService
+  def redeem(coupon_code, order)
+    coupon = Coupon.find_by!(code: coupon_code)
+
+    # クーポンが未使用かチェック
+    raise "Already redeemed" if coupon.redeemed
+
+    # 割引を適用
+    order.apply_discount(coupon.discount_amount)
+    order.save!
+
+    # 使用済みにマーク
+    coupon.update!(redeemed: true, used_at: Time.current)
+    coupon
+  end
+end
