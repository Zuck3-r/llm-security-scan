 class PaymentsController < ApplicationController
   before_action :authenticate_user!
+  # Rails default の CSRF 防御を明示。skip_before_action は使わない。
+  protect_from_forgery with: :exception

+  def transfer
+    Payment.create!(user: current_user, amount: params[:amount], to: params[:to_account])
+    redirect_to payments_path, notice: "送金しました"
+  end
 end
